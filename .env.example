# .env.example (образец для посвящённых учеников)
BOT_TOKEN=токен_от_Бога_Отца_Магистра
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/cult_db
REDIS_URL=redis://user:pass@host:6379/0  # если будет Redis
ADMIN_IDS=123456789,987654321  # ID кентов через запятую
MAGISTER_WISDOM_CHANCE=0.3  # шанс что Магистр выдаст мудрость после тренировки (30%)
DASHA_THREAT_LEVEL=medium  # начальный уровень угрозы Дашки (low/medium/high/armageddon)
